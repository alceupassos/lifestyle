# =============================================================
# LIFE STYLE — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# =============================================================

# ── Shopify ──────────────────────────────────────────────────
# Seu domínio Shopify (sem https://)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=sua-loja.myshopify.com

# Token público do Storefront API (para queries de produtos no frontend)
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token privado do Admin API (apenas server-side)
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Versão da API Shopify
SHOPIFY_API_VERSION=2025-04

# Webhook Secret (gerado ao criar webhook no Partner Dashboard)
SHOPIFY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── fashn.ai ─────────────────────────────────────────────────
# Sua API Key do fashn.ai (Settings → API → + Create new API key)
FASHN_API_KEY=fa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Life Style

# ── Opcional: Analytics ──────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
